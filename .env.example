# ──────────────────────────────────────────────
# LLM provider: ollama (local, default) ou openai
# ──────────────────────────────────────────────
LLM_PROVIDER=ollama

# Ollama — runs locally, no API key needed
OLLAMA_MODEL=llama3.2
OLLAMA_URL=http://localhost:11434

# OpenAI — descomente e preencha se LLM_PROVIDER=openai
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini

# ──────────────────────────────────────────────
# Embeddings (bge-m3)
# ──────────────────────────────────────────────
EMBEDDING_MODEL=paraphrase-multilingual-MiniLM-L12-v2

# Silencia o warning de token não autenticado do HuggingFace Hub
HF_HUB_VERBOSITY=error

# Impede que o HuggingFace Hub faça requisições de rede ao carregar modelos já
# em cache (elimina os logs HTTP do httpx). Remova esta linha apenas se precisar
# baixar um novo modelo de embedding.
HF_HUB_OFFLINE=1

# ──────────────────────────────────────────────
# Vector store
# ──────────────────────────────────────────────
VECTORDB_PATH=vectordb
COLLECTION_NAME=normativos


# ──────────────────────────────────────────────
# RAGAS — avaliação automática do pipeline RAG
# (usado apenas pelo orchestrator_rag_eval.py)
# ──────────────────────────────────────────────

# Provider do modelo julgador: openai ou ollama (local)
RAGAS_LLM_PROVIDER=ollama

# Modelo julgador via Ollama
# Certifique-se de ter o modelo puxado: ollama pull deepseek-r1:14b
RAGAS_JUDGE_MODEL=deepseek-r1:14b

# Modelo de embeddings para métricas que precisam de semelhança semântica
# Certifique-se de ter: ollama pull nomic-embed-text
RAGAS_EMBEDDING_MODEL=nomic-embed-text

# Se preferir OpenAI como julgador (mais confiável para parsing de JSON):
# RAGAS_LLM_PROVIDER=openai
# RAGAS_JUDGE_MODEL=gpt-4o
# RAGAS_EMBEDDING_MODEL=text-embedding-3-small
# OPENAI_API_KEY=sk-...
